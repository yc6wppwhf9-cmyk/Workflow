# Supabase project URL — found in Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Cloudinary — image uploads and CDN (https://cloudinary.com)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Email notifications via Resend (optional — notifications are skipped if not set)
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=PLM System <noreply@yourdomain.com>

# Public app URL (used in email links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Web Push notifications (VAPID) — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CONTACT_EMAIL=mailto:admin@yourdomain.com

# Default password assigned to newly created users (must be changed on first login)
DEFAULT_USER_PASSWORD=Welcome@2026
